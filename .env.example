# Assistant identity
ASSISTANT_NAME=Katie
# Name used when introducing the assistant to non-owner callers.
# ("Hi, I'm Katie, {OWNER_NAME}'s assistant.")
OWNER_NAME=Sascha
# Personality: professional | friendly | casual  (default: friendly)
PERSONALITY=friendly
# Shared memory directory — agent reads MEMORY.md, USER.md, and today's daily
# log from here at call start, and appends a Voice Call summary at call end.
# Set to the same directory text-chat Katie uses (e.g. /Users/sascha/clawd).
# Leave blank to use per-caller profile files under user_memory/ instead.
AGENT_MEMORY_DIR=/Users/sascha/clawd

# Voice engine
ANTHROPIC_API_KEY=your_anthropic_api_key

# SIP (VoIP.ms)
SIP_SERVER=la.voip.ms
SIP_EXTENSION=524638_yoursubaccount
SIP_PASSWORD=your_voipms_subaccount_password
SIP_EXTERNAL_IP=203.0.113.10

# OpenClaw gateway
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token
OPENCLAW_AUTH_PIN=1234

# Optional TTS/STT providers (only needed if selected in config.yaml)
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Optional: original xAI engine (engine: xai in config.yaml)
XAI_API_KEY=your_xai_api_key
