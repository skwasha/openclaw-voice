# Voice engine
ANTHROPIC_API_KEY=your_anthropic_api_key

# SIP (VoIP.ms)
SIP_SERVER=la.voip.ms
SIP_EXTENSION=524638_yoursubaccount
SIP_PASSWORD=your_voipms_subaccount_password
SIP_EXTERNAL_IP=203.0.113.10

# OpenClaw gateway
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token
OPENCLAW_AUTH_PIN=1234

# Optional TTS/STT providers (only needed if selected in config.yaml)
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id

# Optional: original xAI engine (engine: xai in config.yaml)
XAI_API_KEY=your_xai_api_key
